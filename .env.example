# Memento Configuration
#
# Copy this file to .env and fill in your values.
# Never commit the .env file to version control.

# Claude API key for query responses.
# Get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-api-key-here

# PostgreSQL connection.
# Always use password authentication. Never use trust auth.
# Format: postgresql://username:password@host/database
DATABASE_URL=postgresql://your_user:your_password@localhost/memento

# Path to Claude Code conversation transcripts.
# Default is the standard Claude Code location.
TRANSCRIPT_DIR=~/.claude/projects/-Users-ct-Python/

# Embedding model name (sentence-transformers).
# all-MiniLM-L6-v2 is fast and produces 384-dimension vectors.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Claude model to use for query responses.
CLAUDE_MODEL=claude-sonnet-4-6

# Number of transcript chunks to retrieve per query.
RETRIEVAL_LIMIT=10

# Anonymization mapping file path.
# This JSON file maps real names to placeholders.
ANONYMIZER_MAPPING=anonymizer_mapping.json

# Anonymization allowlist file path.
# This JSON array lists public entity names that should not be anonymized.
ANONYMIZER_ALLOWLIST=anonymizer_allowlist.json
